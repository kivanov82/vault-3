# Your Hyperliquid Vault Configuration
WALLET=0xYourVaultAddress           # Your vault address (vault-3)
WALLET_PK=0xYourPrivateKey
VAULT_LEADER=0xYourLeaderAddress    # Wallet that controls the vault

# Copytrading — multi-target (comma-separated)
# Supports both vaults and personal wallets — both are queried via clearinghouseState
COPY_TRADERS=0xb1505ad1a4c7755e0eb236aa2f4327bfc3474768,0x8c7bd04cf8d00d68ce8bc7d2f3f02f98d16a5ab0,0xbd9c944dcfb31cd24c81ebf1c974d950f44e42b8

COPY_MODE=scaled                    # 'scaled' or 'exact'
COPY_POLL_INTERVAL_MINUTES=5        # Position scan frequency
COPY_SCALE_MULTIPLIER=3.0           # Multiplier on aggregated target margin

# Phase Control
ENABLE_COPY_TRADING=true
ENABLE_INDEPENDENT_TRADING=true

# Independent Trading — all values shown below are CODE DEFAULTS
# (uncomment to override; defaults live in IndependentTrader.ts)
# INDEPENDENT_MAX_ALLOCATION_PCT=0.30   # 30% of vault
# INDEPENDENT_MAX_POSITIONS=5           # max concurrent positions
# INDEPENDENT_LEVERAGE=5                # 5x leverage
# INDEPENDENT_MAX_HOLD_HOURS=72         # 72h max hold
# INDEPENDENT_HARD_STOP_PCT=0.10        # -10% price move from entry

# Database — Google Cloud SQL
# Local development:
DATABASE_URL=postgresql://user:password@host:5432/vault3?sslmode=no-verify
# Cloud Run (Unix socket):
# DATABASE_URL=postgresql://user:password@/vault3?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_ID

# Server
PORT=3000

# Logging
DEBUG=false
LOG_LEVEL=info

# Risk Management
MIN_POSITION_SIZE_USD=5             # Minimum position size (avoid dust)

# Data Collection
ENABLE_FUNDING_COLLECTION=true
TWAP_DETECTION_WINDOW_SECONDS=300   # 5-minute window for TWAP aggregation
